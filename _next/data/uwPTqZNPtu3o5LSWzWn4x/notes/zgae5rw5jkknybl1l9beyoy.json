iki","from":{"fname":"open-notebook.commons.ablood.literature.computer-science.programming-languages.saturation-arithmetic","id":"zgae5rw5jkknybl1l9beyoy","vaultName":"vault"},"value":"tags.saturation_arithmetic","alias":"#saturation_arithmetic","position":{"start":{"line":29,"column":106,"offset":1554},"end":{"line":29,"column":128,"offset":1576},"indent":[]},"xvault":false,"to":{"fname":"tags.saturation_arithmetic"}},{"type":"wiki","from":{"fname":"open-notebook.commons.ablood.literature.computer-science.programming-languages.saturation-arithmetic","id":"zgae5rw5jkknybl1l9beyoy","vaultName":"vault"},"value":"tags.mathematics","alias":"#mathematics","position":{"start":{"line":29,"column":129,"offset":1577},"end":{"line":29,"column":141,"offset":1589},"indent":[]},"xvault":false,"to":{"fname":"tags.mathematics"}},{"type":"wiki","from":{"fname":"open-notebook.commons.ablood.literature.computer-science.programming-languages.saturation-arithmetic","id":"zgae5rw5jkknybl1l9beyoy","vaultName":"vault"},"value":"tags.rust","alias":"#rust","position":{"start":{"line":29,"column":142,"offset":1590},"end":{"line":29,"column":147,"offset":1595},"indent":[]},"xvault":false,"to":{"fname":"tags.rust"}},{"type":"wiki","from":{"fname":"open-notebook.commons.ablood.literature.computer-science.programming-languages.saturation-arithmetic","id":"zgae5rw5jkknybl1l9beyoy","vaultName":"vault"},"value":"tags.rustlang","alias":"#rustlang","position":{"start":{"line":29,"column":148,"offset":1596},"end":{"line":29,"column":157,"offset":1605},"indent":[]},"xvault":false,"to":{"fname":"tags.rustlang"}}],"anchors":{"part-1-wikipedia":{"type":"header","text":"Part 1: Wikipedia","value":"part-1-wikipedia","line":9,"column":0,"depth":1},"modern-use":{"type":"header","text":"Modern Use","value":"modern-use","line":17,"column":0,"depth":2},"part-2-rust-forum-post":{"type":"header","text":"Part 2: Rust Forum Post","value":"part-2-rust-forum-post","line":20,"column":0,"depth":1},"part-3-rust-stdnum-documentation":{"type":"header","text":"Part 3: Rust std::num Documentation","value":"part-3-rust-stdnum-documentation","line":27,"column":0,"depth":1}},"children":[],"parent":"s1kltw8a22q1qcppfnt4l4q","data":{}},"body":"<h1 id=\"saturation-arithmetic\"><a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#saturation-arithmetic\"></a>Saturation Arithmetic</h1>\n<h1 id=\"part-1-wikipedia\"><a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#part-1-wikipedia\"></a><a href=\"https://en.wikipedia.org/wiki/Saturation_arithmetic\">Part 1: Wikipedia</a></h1>\n<p><strong>Saturation Arithmetic</strong>: all arithmetic operations are limited to a fixed range <em>min</em> and <em>max</em> value.</p>\n<p>If result is > or &#x3C; these values then it is <strong>clamped</strong> to that value.\ne.g.:</p>\n<ul>\n<li><span class=\"math math-inline\"><span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mn>60</mn><mo>+</mo><mn>30</mn><mo>→</mo><mn>90</mn></mrow><annotation encoding=\"application/x-tex\">60+30 \\rightarrow 90</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.7278em;vertical-align:-0.0833em;\"></span><span class=\"mord\">60</span><span class=\"mspace\" style=\"margin-right:0.2222em;\"></span><span class=\"mbin\">+</span><span class=\"mspace\" style=\"margin-right:0.2222em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:0.6444em;\"></span><span class=\"mord\">30</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span><span class=\"mrel\">→</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:0.6444em;\"></span><span class=\"mord\">90</span></span></span></span></span></li>\n<li><span class=\"math math-inline\"><span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mn>60</mn><mo>+</mo><mn>43</mn><mo>→</mo><mn>100</mn></mrow><annotation encoding=\"application/x-tex\">60+43 \\rightarrow 100</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.7278em;vertical-align:-0.0833em;\"></span><span class=\"mord\">60</span><span class=\"mspace\" style=\"margin-right:0.2222em;\"></span><span class=\"mbin\">+</span><span class=\"mspace\" style=\"margin-right:0.2222em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:0.6444em;\"></span><span class=\"mord\">43</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span><span class=\"mrel\">→</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:0.6444em;\"></span><span class=\"mord\">100</span></span></span></span></span> (not 103)</li>\n<li><span class=\"math math-inline\"><span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mo stretchy=\"false\">(</mo><mn>60</mn><mo>+</mo><mn>43</mn><mo stretchy=\"false\">)</mo><mo>−</mo><mo stretchy=\"false\">(</mo><mn>75</mn><mo>+</mo><mn>25</mn><mo stretchy=\"false\">)</mo><mo>→</mo><mn>0</mn></mrow><annotation encoding=\"application/x-tex\">(60+43) - (75+25) \\rightarrow 0</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mopen\">(</span><span class=\"mord\">60</span><span class=\"mspace\" style=\"margin-right:0.2222em;\"></span><span class=\"mbin\">+</span><span class=\"mspace\" style=\"margin-right:0.2222em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mord\">43</span><span class=\"mclose\">)</span><span class=\"mspace\" style=\"margin-right:0.2222em;\"></span><span class=\"mbin\">−</span><span class=\"mspace\" style=\"margin-right:0.2222em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mopen\">(</span><span class=\"mord\">75</span><span class=\"mspace\" style=\"margin-right:0.2222em;\"></span><span class=\"mbin\">+</span><span class=\"mspace\" style=\"margin-right:0.2222em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mord\">25</span><span class=\"mclose\">)</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span><span class=\"mrel\">→</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:0.6444em;\"></span><span class=\"mord\">0</span></span></span></span></span> , rather than 3 </li>\n</ul>\n<h2 id=\"modern-use\"><a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#modern-use\"></a>Modern Use</h2>\n<p>In computing it is useful for getting as close numerically to the true answer as possible, rather than the wrap around that occurs with modular arithmetic. </p>\n<ul>\n<li>also enhances algorithms in many problems. </li>\n</ul>\n<h1 id=\"part-2-rust-forum-post\"><a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#part-2-rust-forum-post\"></a><a href=\"https://users.rust-lang.org/t/saturating-what-does-it-really-do-and-when-is-it-useful/52720\">Part 2: Rust Forum Post</a></h1>\n<p>Integers have finite ranges (0 to <span class=\"math math-inline\"><span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><msup><mn>2</mn><mi>n</mi></msup><mo>−</mo><mn>1</mn></mrow><annotation encoding=\"application/x-tex\">2^n-1</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.7477em;vertical-align:-0.0833em;\"></span><span class=\"mord\"><span class=\"mord\">2</span><span class=\"msupsub\"><span class=\"vlist-t\"><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.6644em;\"><span style=\"top:-3.063em;margin-right:0.05em;\"><span class=\"pstrut\" style=\"height:2.7em;\"></span><span class=\"sizing reset-size6 size3 mtight\"><span class=\"mord mathnormal mtight\">n</span></span></span></span></span></span></span></span><span class=\"mspace\" style=\"margin-right:0.2222em;\"></span><span class=\"mbin\">−</span><span class=\"mspace\" style=\"margin-right:0.2222em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:0.6444em;\"></span><span class=\"mord\">1</span></span></span></span></span>) depending on the bits n they use:</p>\n<ul>\n<li>u8: 0 - <span class=\"math math-inline\"><span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><msup><mn>2</mn><mn>8</mn></msup></mrow><annotation encoding=\"application/x-tex\">2^8</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.8141em;\"></span><span class=\"mord\"><span class=\"mord\">2</span><span class=\"msupsub\"><span class=\"vlist-t\"><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.8141em;\"><span style=\"top:-3.063em;margin-right:0.05em;\"><span class=\"pstrut\" style=\"height:2.7em;\"></span><span class=\"sizing reset-size6 size3 mtight\"><span class=\"mord mtight\">8</span></span></span></span></span></span></span></span></span></span></span></span> - 1 (255)\nThere are three options to handle an arithmetic operation that results in a value that does not fit this finite range:\n1) wrap around\n2) saturate at the <span class=\"math math-inline\"><span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><msup><mn>2</mn><mi>n</mi></msup><mo>−</mo><mn>1</mn></mrow><annotation encoding=\"application/x-tex\">2^n-1</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.7477em;vertical-align:-0.0833em;\"></span><span class=\"mord\"><span class=\"mord\">2</span><span class=\"msupsub\"><span class=\"vlist-t\"><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.6644em;\"><span style=\"top:-3.063em;margin-right:0.05em;\"><span class=\"pstrut\" style=\"height:2.7em;\"></span><span class=\"sizing reset-size6 size3 mtight\"><span class=\"mord mathnormal mtight\">n</span></span></span></span></span></span></span></span><span class=\"mspace\" style=\"margin-right:0.2222em;\"></span><span class=\"mbin\">−</span><span class=\"mspace\" style=\"margin-right:0.2222em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:0.6444em;\"></span><span class=\"mord\">1</span></span></span></span></span> for addition and 0 for subtraction\n3) check the value and result in a panic (rust specific)</li>\n</ul>\n<h1 id=\"part-3-rust-stdnum-documentation\"><a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#part-3-rust-stdnum-documentation\"></a><a href=\"https://doc.rust-lang.org/beta/std/num/struct.Saturating.html\">Part 3: Rust std::num Documentation</a></h1>\n<p>Although values for <code>u32</code> should never overflow, sometimes in certain debug situations a panic may result. Thus saturation can be used.\nExample: </p>\n<pre class=\"language-rust\"><code class=\"language-rust\"><span class=\"token keyword\">use</span> <span class=\"token namespace\">std<span class=\"token punctuation\">::</span>num<span class=\"token punctuation\">::</span></span><span class=\"token class-name\">Saturating</span><span class=\"token punctuation\">;</span>\n<span class=\"token keyword\">let</span> max <span class=\"token operator\">=</span> <span class=\"token class-name\">Saturating</span><span class=\"token punctuation\">(</span><span class=\"token keyword\">u32</span><span class=\"token punctuation\">::</span><span class=\"token constant\">MAX</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n<span class=\"token keyword\">let</span> one <span class=\"token operator\">=</span> <span class=\"token class-name\">Saturating</span><span class=\"token punctuation\">(</span><span class=\"token number\">1u32</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n<span class=\"token macro property\">assert_eq!</span><span class=\"token punctuation\">(</span><span class=\"token keyword\">u32</span><span class=\"token punctuation\">::</span><span class=\"token constant\">MAX</span><span class=\"token punctuation\">,</span> <span class=\"token punctuation\">(</span>max_one<span class=\"token punctuation\">)</span><span class=\"token punctuation\">.</span><span class=\"token number\">0</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n</code></pre>\n<p><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">#concepts (Private)</a> <a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">#computerscience (Private)</a> <a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">#arithmetic (Private)</a> <a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">#algorithms (Private)</a>  <a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">#notes (Private)</a> <a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">#research (Private)</a> 