25,"column":43,"offset":757},"indent":[]},"value":"expanded_np_chemspace.abbreviations"},{"from":{"id":"djevq0ph906el088jgs0cvs","fname":"open-notebook.commons.pamrein.2024.03.28","vaultName":"vault"},"type":"backlink","position":{"start":{"line":30,"column":1,"offset":727},"end":{"line":30,"column":43,"offset":769},"indent":[]},"value":"expanded_np_chemspace.abbreviations"}],"anchors":{"keywords":{"type":"header","text":"Keywords","value":"keywords","line":9,"column":0,"depth":2}},"children":[],"parent":"b6a9vzvot1o5s7g65kp45rd","data":{}},"body":"<h1 id=\"abbreviations\"><a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#abbreviations\"></a>Abbreviations</h1>\n<h2 id=\"keywords\"><a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#keywords\"></a>Keywords</h2>\n<p>NP - Natural Products<br>\nDNP - Dictionary of Natural Products (commercially available effors for comiling NP data - <a href=\"https://dnp.chemnetbase.com/\">https://dnp.chemnetbase.com/</a>)<br>\nLNPN - <a href=\"https://lotus.naturalproducts.net\">LOTUS database</a><br>\nSSOT - Single Source of Truth<br>\nOTL - Open Tree of life<br>\nIDSM - Integrated Database of Small Molecules<br>\nSMILES - Simplified Molecular Input Line Entry System (represents chemical structures in a linear string)\nBNICE - Biochemical Network Integated Computational Explorer (enzymatic algorythms)<br>\nKEGG - Kyoto Encyclopedia of Genes and Genomes (database)<br>\nSMARTS - \"SMiles ARbitrary Target Specification\"\nSMIRKS - \"Simplified Molecular Input Line Entry System\" is a hybrid of SMILES and SMARTS. It represent reactions in a string.\nFP2 - Fingerprints<br>\nFP4 - Fingerprints<br>\n<a href=\"https://minedatabase.mcs.anl.gov/#/home\">MINEs</a> - Metabolic In silico Network Expansions (predicted enzyme promiscuity products - database)\nBAM - Biotransformation-based Annotation Method<br>\nCOMMONS Lab - COMputational Metabolomics &#x26; Open science for Natural products reSearch<br>\n<a href=\"http://smart.embl-heidelberg.de/\">SMART</a> - (Simple Modular Architecture Research Tool) is a used for the identification and annotation of protein domains within protein sequences.<br>\n*.sdf - text-based file for storing chemical information (structure, ...).</p>\n<hr>\n<strong>Backlinks</strong>\n<ul>\n<li><a href=\"/commons-dws-public/notes/loztevovn8nanzdk302b756\">Papers</a></li>\n<li><a href=\"/commons-dws-public/notes/ozp2qt78t5st6m7zdgzuihd\">Pamrein</a></li>\n<li><a href=\"/commons-dws-public/notes/9u4rjkrv1018glbpx8rvk0c\">2024-02-26</a></li>\n<li><a href=\"/commons-dws-public/notes/lqgtmm63ylloejro23g40r2\">2024-02-27</a></li>\n<li><a href=\"/commons-dws-public/notes/xd9ywk039liy4aim6negubf\">2024-02-28</a></li>\n<li><a href=\"/commons-dws-public/notes/szdrijhisrocpfc7s49wifq\">2024-02-29</a></li>\n<li><a href=\"/commons-dws-public/notes/9ujizb66ixjx3tam04inay6\">2024-03-01</a></li>\n<li><a href=\"/commons-dws-public/notes/u704xipircddc7bnvx8dkfq\">2024-03-05</a></li>\n<li><a href=\"/commons-dws-public/notes/3m2e1tzzsksm5kys7v7ww5v\">2024-03-07</a></li>\n<li><a href=\"/commons-dws-public/notes/0wn91vsfjkhnh6rpn6j51ox\">2024-03-08</a></li>\n<li><a href=\"/commons-dws-public/notes/1jivqvouqqyhtirzxj3yawg\">2024-03-11</a></li>\n<li><a href=\"/commons-dws-public/notes/pksd91qjq8riuidvw6oikak\">2024-03-12</a></li>\n<li><a href=\"/commons-dws-public/notes/zlarzdpslhdwyd1wq0kzkri\">2024-03-14</a></li>\n<li><a href=\"/commons-dws-public/notes/k7u8noz50sc8c97yg6nl5yf\">2024-03-15</a></li>\n<li><a href=\"/commons-dws-public/notes/otovollyg76dr06ocdyuhxj\">2024-03-19</a></li>\n<li><a href=\"/commons-dws-public/notes/r7sp2ukd77djf2uewciy3hx\">2024-03-20</a></li>\n<li><a href=\"/commons-dws-public/notes/yxa8l1dmf2qpky2jhthnr0g\">2024-03-21</a></li>\n<li><a href=\"/commons-dws-public/notes/k9y9qbrbjnbjtm4ex8hxeqj\">2024-03-22</a></li>\n<li><a href=\"/commons-dws-public/notes/m6gc6c6ezndqyyhgchgmxhj\">2024-03-26</a></li>\n<li><a href=\"/commons-dws-public/notes/e6tzwf